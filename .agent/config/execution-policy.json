{
  "$comment": "Execution Policy Schema v1.1 - Agent Skill Kit v3.3.0",
  "version": "1.1",
  "codebaseVersion": "3.3.0",
  "description": "Execution policy for workflow auto-accept authorization",
  
  "autoAccept": {
    "enabled": true,
    "defaultMode": "prompt",
    "requireAnnotation": true,
    "requiredAnnotations": ["auto", "safe"],
    
    "allowPatterns": [
      { "pattern": "^npm run [a-z0-9:-]+$", "type": "regex", "description": "npm run with safe script names" },
      { "pattern": "^pnpm run [a-z0-9:-]+$", "type": "regex" },
      { "pattern": "^yarn run [a-z0-9:-]+$", "type": "regex" },
      { "pattern": "node .agent/", "type": "prefix", "description": "node scripts in .agent/" },
      { "pattern": "node --version", "type": "exact" },
      { "pattern": "npm --version", "type": "exact" },
      { "pattern": "git status", "type": "exact" },
      { "pattern": "git log", "type": "prefix" },
      { "pattern": "git diff", "type": "prefix" },
      { "pattern": "git branch", "type": "prefix" },
      { "pattern": "echo ", "type": "prefix" },
      { "pattern": "pwd", "type": "exact" },
      { "pattern": "python --version", "type": "exact" },
      { "pattern": "python3 --version", "type": "exact" }
    ],
    
    "denyPatterns": [
      { "pattern": "rm -rf", "type": "contains", "severity": "critical" },
      { "pattern": "rm -r", "type": "contains", "severity": "critical" },
      { "pattern": "rmdir /s", "type": "contains", "severity": "critical" },
      { "pattern": "del /f", "type": "contains", "severity": "high" },
      { "pattern": "del /s", "type": "contains", "severity": "high" },
      { "pattern": "format", "type": "prefix", "severity": "critical" },
      { "pattern": "shutdown", "type": "prefix", "severity": "critical" },
      { "pattern": "git push", "type": "prefix", "severity": "high" },
      { "pattern": "git reset --hard", "type": "contains", "severity": "critical" },
      { "pattern": "git clean -fd", "type": "contains", "severity": "high" },
      { "pattern": "npm publish", "type": "prefix", "severity": "high" },
      { "pattern": "npm unpublish", "type": "prefix", "severity": "critical" },
      { "pattern": "-e ['\"].*exec", "type": "regex", "severity": "critical", "description": "node -e with exec" },
      { "pattern": "eval\\(", "type": "regex", "severity": "critical" },
      { "pattern": "> /dev/null", "type": "contains", "severity": "medium" },
      { "pattern": "| rm", "type": "contains", "severity": "critical" },
      { "pattern": "&& rm", "type": "contains", "severity": "critical" },
      { "pattern": "Remove-Item -Recurse", "type": "contains", "severity": "critical", "description": "PowerShell recursive delete" },
      { "pattern": "Remove-Item -Force", "type": "contains", "severity": "high" },
      { "pattern": "Clear-RecycleBin", "type": "prefix", "severity": "high" },
      { "pattern": "Stop-Computer", "type": "prefix", "severity": "critical" },
      { "pattern": "Restart-Computer", "type": "prefix", "severity": "critical" }
    ],
    
    "allow": [
      "npm run",
      "pnpm run", 
      "yarn run",
      "node ",
      "echo ",
      "git status",
      "git log",
      "git diff"
    ],
    
    "deny": [
      "rm -rf",
      "git push",
      "npm publish"
    ]
  },
  
  "phaseGate": {
    "requirePlanApproval": true,
    "allowedModes": ["dry-run", "turbo", "auto-accept"]
  },
  
  "annotations": {
    "recognized": ["auto", "safe", "confirm", "ci", "readonly", "interactive"],
    "warnOnUnknown": true,
    "strictMode": false
  },
  
  "logging": {
    "logAutoAccept": true,
    "logBlocked": true,
    "logPolicyDrift": true,
    "historyFile": ".agent/logs/execution-history.jsonl"
  }
}
