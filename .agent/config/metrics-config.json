{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Agent Metrics Configuration",
    "version": "1.0.0",
    "description": "Configuration for mandatory metrics collection during autopilot execution",
    "metrics": {
        "time_to_completion": {
            "type": "duration",
            "unit": "seconds",
            "target": "minimize",
            "required": true
        },
        "skill_reuse_rate": {
            "type": "percentage",
            "target": ">50%",
            "formula": "skills_reused / skills_invoked",
            "required": true
        },
        "human_intervention_count": {
            "type": "counter",
            "target": 0,
            "description": "Number of notify_user calls during autopilot",
            "required": true
        },
        "error_retry_rate": {
            "type": "percentage",
            "target": "<10%",
            "formula": "retries / total_operations",
            "required": true
        },
        "agent_handoff_count": {
            "type": "counter",
            "target": "minimize",
            "description": "Number of agent switches",
            "required": true
        },
        "first_time_success_rate": {
            "type": "percentage",
            "target": ">85%",
            "formula": "success_no_retry / total_executions",
            "required": true
        },
        "auto_fix_rate": {
            "type": "percentage",
            "target": ">85%",
            "formula": "auto_fixed / total_problems",
            "required": true
        },
        "plan_adherence": {
            "type": "percentage",
            "target": "100%",
            "formula": "deliverables_complete / deliverables_planned",
            "required": true
        },
        "checkpoint_usage": {
            "type": "counter",
            "target": ">=1 for risky operations",
            "required": true
        },
        "rollback_count": {
            "type": "counter",
            "target": 0,
            "required": true
        },
        "total_phases_completed": {
            "type": "counter",
            "description": "Phases completed out of planned",
            "required": true
        }
    },
    "storage": {
        "location": ".agent/metrics/",
        "format": "json",
        "retention_days": 30,
        "aggregation": [
            "daily",
            "weekly",
            "monthly"
        ]
    },
    "improvement": {
        "baseline_window": 10,
        "alert_threshold_degradation": 0.10,
        "celebrate_threshold_improvement": 0.20
    },
    "recording_triggers": {
        "execution_start": [
            "timestamp",
            "context"
        ],
        "phase_complete": [
            "duration",
            "status"
        ],
        "agent_switch": [
            "from_agent",
            "to_agent",
            "reason"
        ],
        "error_occurred": [
            "type",
            "severity",
            "resolution"
        ],
        "execution_end": [
            "all_metrics"
        ]
    }
}