{
  "version": "3.9.122",
  "notification": {
    "enabled": true,
    "verbosity": "normal",
    "channels": [
      "console"
    ]
  },
  "branding": {
    "name": "PikaKit",
    "emoji": "🤖",
    "tagline": "Composable Skills. Coordinated Agents. Intelligent Execution.",
    "footer": "⚡ PikaKit v{version}"
  },
  "templates": {
    "taskStart": "🤖 **PikaKit v{version}** | Workflow: /{workflow}\n◆ Agent: @{agent}\n◇ Skills: {skills}",
    "taskComplete": "✅ **Complete** | Agent: @{agent} | Skills: {skillCount} | Files: {fileCount} | {duration}s",
    "compact": "🤖 PikaKit ⬢ @{agent} → {skills}",
    "skillLoad": "🤖 **PikaKit Loading Skill:** @{skill}",
    "scriptRun": "⚡ {skill} ⬢ running {script}",
    "error": "❌ **Failed** | Agent: @{agent} | Phase: {phase} | {error}"
  },
  "behavior": {
    "showOnWorkflowExecution": true,
    "showOnSimpleEdits": false,
    "showFooterOnCompletion": true,
    "suppressDuplicateSkillLoads": true,
    "compactModeThreshold": 2
  },
  "telemetry": {
    "enabled": false,
    "traceExecution": false,
    "logLevel": "info"
  }
}
