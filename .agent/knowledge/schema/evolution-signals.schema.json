{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pikakit.com/schemas/evolution-signals.schema.json",
  "title": "Evolution Signals",
  "description": "Schema for evolution-signals.json - auto-evolution triggers",
  "type": "object",
  
  "required": ["version", "signals"],
  
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/signal"
      }
    }
  },
  
  "definitions": {
    "signal": {
      "type": "object",
      "required": ["id", "lessonId", "reason", "confidence", "status", "createdAt"],
      
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^signal_\\d+_[a-z0-9]+$",
          "description": "Unique signal identifier"
        },
        
        "lessonId": {
          "type": "string",
          "pattern": "^(LEARN|MISTAKE|IMPROVE)-\\d{3,}$"
        },
        
        "reason": {
          "type": "string",
          "enum": ["hitCountThreshold", "confidenceThreshold", "ageThreshold", "userRequested"],
          "description": "Why this signal was triggered"
        },
        
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "expired"],
          "description": "Current state of the signal"
        },
        
        "metadata": {
          "type": "object",
          "properties": {
            "triggerEvent": {
              "type": "string",
              "enum": ["violation", "scan", "manual"]
            },
            "file": {
              "type": "string"
            },
            "matchCount": {
              "type": "integer",
              "minimum": 0
            },
            "timestamp": {
              "type": "integer"
            }
          }
        },
        
        "createdAt": {
          "type": "integer",
          "description": "Unix timestamp when signal was created"
        },
        
        "resolvedAt": {
          "type": ["integer", "null"],
          "description": "Unix timestamp when signal was resolved"
        }
      },
      
      "additionalProperties": false
    }
  }
}
