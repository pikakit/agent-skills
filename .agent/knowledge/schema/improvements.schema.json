{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pikakit.com/schemas/improvements.schema.json",
  "title": "Improvements Knowledge Base",
  "description": "Schema for improvements.yaml - best practices and optimizations",
  "type": "object",
  
  "required": ["version", "improvements"],
  
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for migrations"
    },
    
    "improvements": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/improvement"
      }
    }
  },
  
  "definitions": {
    "improvement": {
      "type": "object",
      "required": ["id", "pattern", "message"],
      
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^IMPROVE-\\d{3,}$",
          "description": "Unique improvement identifier"
        },
        
        "pattern": {
          "type": "string",
          "minLength": 1,
          "description": "Regex pattern to detect improvement opportunity"
        },
        
        "message": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Suggested improvement"
        },
        
        "hitCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        
        "lastHit": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        
        "excludePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        
        "intent": {
          "type": "string",
          "enum": ["optimize"],
          "default": "optimize"
        },
        
        "patternType": {
          "type": "string",
          "enum": ["general", "structure", "dependency", "security", "performance", "quality"],
          "default": "general"
        },
        
        "context": {
          "type": "object",
          "properties": {
            "appliesTo": {
              "type": "object"
            },
            "scope": {
              "type": "string",
              "enum": ["global", "local"],
              "default": "local"
            }
          }
        },
        
        "cognitive": {
          "type": "object",
          "properties": {
            "maturity": {
              "type": "string",
              "enum": ["learning", "stable", "deprecated"],
              "default": "learning"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.3
            }
          }
        },
        
        "appliedCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of times this improvement was applied"
        },
        
        "lastApplied": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      
      "additionalProperties": false
    }
  }
}
