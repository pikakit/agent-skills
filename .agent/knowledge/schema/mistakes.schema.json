{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentskillkit.com/schemas/mistakes.schema.json",
  "title": "Mistakes Knowledge Base",
  "description": "Schema for mistakes.yaml - anti-patterns to prevent",
  "type": "object",
  
  "required": ["version", "mistakes"],
  
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for migrations"
    },
    
    "mistakes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/mistake"
      }
    }
  },
  
  "definitions": {
    "mistake": {
      "type": "object",
      "required": ["id", "pattern", "message", "severity"],
      
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^MISTAKE-\\d{3,}$",
          "description": "Unique mistake identifier"
        },
        
        "pattern": {
          "type": "string",
          "minLength": 1,
          "description": "Regex pattern to detect mistake"
        },
        
        "message": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500,
          "description": "Explanation of why this is a mistake"
        },
        
        "severity": {
          "type": "string",
          "enum": ["ERROR", "WARNING"],
          "description": "How critical is this mistake"
        },
        
        "hitCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        
        "lastHit": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        
        "excludePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        
        "intent": {
          "type": "string",
          "enum": ["prevent", "warn"],
          "default": "prevent"
        },
        
        "patternType": {
          "type": "string",
          "enum": ["general", "structure", "dependency", "security", "performance", "quality"],
          "default": "general"
        },
        
        "context": {
          "type": "object",
          "properties": {
            "appliesTo": {
              "type": "object"
            },
            "scope": {
              "type": "string",
              "enum": ["global", "local"],
              "default": "local"
            }
          }
        },
        
        "cognitive": {
          "type": "object",
          "properties": {
            "maturity": {
              "type": "string",
              "enum": ["learning", "stable", "deprecated"],
              "default": "learning"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.3
            }
          }
        },
        
        "autoFix": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["replace", "regex-replace", "comment-warning", "insert", "delete"]
            },
            "find": { "type": "string" },
            "replace": { "type": "string" }
          }
        }
      },
      
      "additionalProperties": false
    }
  }
}
