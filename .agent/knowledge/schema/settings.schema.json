{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pikakit.com/schemas/settings.schema.json",
  "title": "Knowledge Settings",
  "description": "Schema for settings.yaml - configuration for knowledge system",
  "type": "object",
  
  "required": ["version"],
  
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    
    "autoLearning": {
      "type": "boolean",
      "default": true,
      "description": "Enable auto-learning from violations"
    },
    
    "autoUpdating": {
      "type": "boolean",
      "default": true,
      "description": "Enable auto-update of hitCount and lastHit"
    },
    
    "updateThreshold": {
      "type": "integer",
      "minimum": 1,
      "default": 10,
      "description": "Hits before triggering evolution signal"
    },
    
    "lastUpdateCheck": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    
    "apiKeys": {
      "type": "object",
      "properties": {
        "gemini": {
          "type": ["string", "null"]
        },
        "claude": {
          "type": ["string", "null"]
        }
      }
    },
    
    "retention": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "archiveAfterDays": {
          "type": "integer",
          "minimum": 30,
          "default": 90
        },
        "deleteAfterDays": {
          "type": "integer",
          "minimum": 60,
          "default": 180
        }
      }
    },
    
    "indexing": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "autoRebuild": {
          "type": "boolean",
          "default": true
        }
      }
    },
    
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "collectInterval": {
          "type": "string",
          "enum": ["onScan", "daily", "weekly"],
          "default": "onScan"
        }
      }
    }
  }
}
