{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Flags Configuration",
  "description": "Schema for .featureflags.json configuration file",
  "type": "object",
  "properties": {
    "flags": {
      "type": "object",
      "description": "Map of flag names to their configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether the flag is enabled",
            "default": false
          },
          "percentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Percentage of users who see the flag (0-100)",
            "default": 100
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the flag"
          },
          "environments": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["development", "staging", "production", "test"]
            },
            "description": "Environments where the flag is active"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "User groups that see the flag"
          },
          "default": {
            "type": "boolean",
            "description": "Default value when flag is disabled",
            "default": false
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "weight": { "type": "number", "minimum": 0 }
              },
              "required": ["name"]
            },
            "description": "A/B test variants with weights"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "percentage": {
          "type": "number",
          "default": 100
        }
      },
      "description": "Default values for new flags"
    },
    "groups": {
      "type": "object",
      "description": "User group definitions",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "required": ["flags"]
}
