{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Schema for Agent Atomic Rules",
    "required": [
        "title",
        "impact",
        "tags"
    ],
    "properties": {
        "title": {
            "type": "string",
            "description": "The human-readable title of the rule"
        },
        "impact": {
            "type": "string",
            "enum": [
                "CRITICAL",
                "HIGH",
                "MEDIUM",
                "LOW"
            ],
            "description": "The severity of the rule violation"
        },
        "impactDescription": {
            "type": "string",
            "description": "Why this rule matters"
        },
        "tags": {
            "type": "string",
            "description": "Comma-separated tags for categorization"
        }
    }
}