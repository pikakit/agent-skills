{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "declaration": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@studio/*": ["./*"]
    }
  },
  "include": [
    "*.js",
    "utils/*.js",
    "types.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
