# EditorConfig v2.0 - Modern JS/TS Project
# https://editorconfig.org

root = true

# ============================================================
# Default for all files
# ============================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ============================================================
# JavaScript & TypeScript
# ============================================================
[*.{js,mjs,cjs,jsx,ts,tsx,vue}]
indent_size = 2
max_line_length = 100
quote_type = single

# ============================================================
# JSON & Configuration Files
# ============================================================
[*.{json,jsonc,json5}]
indent_size = 2

[package.json]
indent_size = 2

[tsconfig*.json]
indent_size = 2

# ============================================================
# YAML Files
# ============================================================
[*.{yml,yaml}]
indent_size = 2

# ============================================================
# Markdown
# ============================================================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ============================================================
# Shell Scripts
# ============================================================
[*.{sh,bash,zsh}]
indent_size = 2

# ============================================================
# Python (Legacy Support)
# ============================================================
[*.py]
indent_size = 4
max_line_length = 88

# ============================================================
# Makefiles (must use tabs)
# ============================================================
[{Makefile,makefile,*.mk}]
indent_style = tab

# ============================================================
# Go Files
# ============================================================
[*.go]
indent_style = tab

# ============================================================
# HTML & CSS
# ============================================================
[*.{html,css,scss,sass,less}]
indent_size = 2

# ============================================================
# XML & SVG
# ============================================================
[*.{xml,svg}]
indent_size = 2
