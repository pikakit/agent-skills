# ============================================================
# Agent Skill Kit Specific
# ============================================================
.gemini/
brain/
artifacts/
antigravity-doc/
rebrand_backup_*/

# Vercel Deploy (temporary deployment packages)
*.tgz
project.tgz
deployment-*.tgz

# PikaKit CLI
.pikakit-cache/
skill-*.lock

# Cloned repos (like vercel-labs/agent-skills)
agent-skills/

# ============================================================
# PikaKit Install Artifacts (avoid accidental commit)
# ============================================================
# Wrapper scripts created by pikakit install
kit
kit.cmd
agent
agent.cmd

# Skill source tracking (created during install)
.agent/skills/*/.skill-source.json

# Agents symlinks (created by pikakit)
.agents/

# Knowledge wiki (created by pikakit CLI)
# Track: structure (.gitkeep), indexes, pattern templates
# Ignore: user-generated signals, compiled articles (per-project data)
.agent/knowledge/raw-signals/*.md
!.agent/knowledge/raw-signals/.gitkeep
.agent/knowledge/raw/*.md
!.agent/knowledge/raw/.gitkeep
.agent/knowledge/concepts/*.md
!.agent/knowledge/concepts/.gitkeep
.agent/knowledge/adr/*.md
!.agent/knowledge/adr/.gitkeep
.agent/knowledge/decisions/*.md
!.agent/knowledge/decisions/.gitkeep

# Runtime binary cache for VS Code semantic search (WASM embedding vector DB)
.agent/memory.sqlite

# ============================================================
# Build Artifacts (PikaKit Engine extensions)
# ============================================================
*.vsix
/icon.png

# ============================================================
# Temporary audit/migration scripts (do not commit)
# ============================================================
audit_refs.ps1
audit_result.txt
