graph TB
    subgraph User_Layer [User Layer]
        User([👤 User])
        Cmd[/"Terminal Command<br>(npx pikakit, kit, /workflow)"/]
    end

    subgraph Orchestration_Layer [Orchestration Layer: Workflows]
        W_Build["/build<br>(App Factory)"]
        W_Plan["/plan<br>(Architect)"]
        W_Launch["/launch<br>(Deploy)"]
        
        noteWorkflows["> Define WHAT to do<br>> Coordainte Phases"]
    end

    subgraph Execution_Layer [Execution Layer: Agents]
        A_Lead["🤖 Lead<br>(Strategic)"]
        A_Orch["🤖 Orchestrator<br>(Management)"]
        
        subgraph Domain_Reviewers
            A_Front["Frontend<br>Specialist"]
            A_Back["Backend<br>Engineer"]
            A_QA["QA<br>Engineer"]
        end
        
        noteAgents["> Define WHO does it<br>> Responsibility & Role"]
    end

    subgraph Knowledge_Layer [Knowledge Layer: Skills]
        S_React["🛠️ react-architect"]
        S_Node["🛠️ nodejs-pro"]
        S_Test["🛠️ test-architect"]
        S_Core["🛠️ code-craft"]
        
        noteSkills["> Define HOW to do it<br>> Tools, Patterns, Resources"]
    end

    %% Relationships
    User -->|Invokes| Cmd
    Cmd -->|Triggers| Orchestration_Layer
    
    W_Build -->|Requests Plan| A_Lead
    W_Build -->|Delegates Tasks| A_Orch
    
    A_Lead -->|Uses| S_Core
    A_Orch -->|Coordinates| Domain_Reviewers
    
    A_Front -->|Loads| S_React
    A_Front -->|Loads| S_Core
    
    A_Back -->|Loads| S_Node
    A_Back -->|Loads| S_Core
    
    A_QA -->|Loads| S_Test
    
    %% Styling
    classDef user fill:#f9fafb,stroke:#6b7280,color:#000;
    classDef workflow fill:#dbeafe,stroke:#3b82f6,color:#1e3a8a;
    classDef agent fill:#d1fae5,stroke:#10b981,color:#064e3b;
    classDef skill fill:#fef3c7,stroke:#f59e0b,color:#78350f;
    
    class User,Cmd user;
    class W_Build,W_Plan,W_Launch,noteWorkflows workflow;
    class A_Lead,A_Orch,A_Front,A_Back,A_QA,noteAgents agent;
    class S_React,S_Node,S_Test,S_Core,noteSkills skill;
