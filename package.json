{
  "name": "pikakit-agent-skills",
  "version": "3.9.26",
  "description": "PikaKit Agent Skills - 50 FAANG-grade skills, 25 workflows, 25 agents for AI-powered development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pikakit/agent-skills.git"
  },
  "homepage": "https://github.com/pikakit/agent-skills",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".agent",
    "docs",
    "packages",
    "tests",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "agent": "./packages/agent/bin/agent.js",
    "kit": "./packages/kit/kit.js"
  },
  "type": "module",
  "scripts": {
    "test": "node packages/agent/tests/integration/signal-detector.test.js",
    "test:integration": "node packages/agent/tests/integration/gemini-export.test.js",
    "test:scripts": "vitest run tests/scripts",
    "example:violations": "node packages/agent/examples/demo-violations.js",
    "rebrand": "node scripts/rebrand/index.mjs",
    "checklist": "node .agent/scripts-js/checklist.js .",
    "verify": "node .agent/scripts-js/verify_all.js . --url",
    "preview:start": "node .agent/scripts-js/auto_preview.js start",
    "preview:stop": "node .agent/scripts-js/auto_preview.js stop",
    "preview:status": "node .agent/scripts-js/auto_preview.js status",
    "session:status": "node .agent/scripts-js/session_manager.js status .",
    "session:info": "node .agent/scripts-js/session_manager.js info .",
    "studio:search": "node .agent/skills/studio/scripts-js/search.js",
    "studio:design": "node .agent/skills/studio/scripts-js/search.js --design-system",
    "test:studio": "vitest run tests/scripts/css-templates.test.js tests/scripts/component-specs.test.js tests/scripts/format-master-md.test.js tests/scripts/page-type-detector.test.js tests/scripts/intelligent-overrides.test.js tests/scripts/page-override-formatter.test.js tests/scripts/css-validator.test.js tests/scripts/search-cache.test.js tests/scripts/config-loader.test.js tests/scripts/integration/studio-integration.test.js",
    "test:unit": "vitest run tests/scripts --exclude tests/scripts/integration/*",
    "test:all": "npm run test && npm run test:integration && npm run test:studio",
    "scan:security": "python .agent/skills/vulnerability-scanner/scripts/security_scan.py .",
    "lint": "python .agent/skills/lint-and-validate/scripts/lint_runner.py .",
    "learn": "node packages/agent/lib/learn.js",
    "workflow:validate": "node .agent/scripts-js/workflow-validator.js",
    "workflow:list": "node .agent/scripts-js/workflow-engine.js --list",
    "workflow:run": "node .agent/scripts-js/workflow-engine.js",
    "agent": "agent",
    "kit": "kit"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "self-learning",
    "pikakit",
    "enterprise"
  ],
  "author": "pikakit <pikakit@gmail.com>",
  "license": "UNLICENSED",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "add-skill-kit": "^3.2.10",
    "eslint": "^9.0.0",
    "gray-matter": "^4.0.3",
    "pikakit-cli": "file:packages/agent",
    "prettier": "^3.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "boxen": "^8.0.1",
    "css-tree": "^3.1.0",
    "csv-parse": "^6.1.0",
    "glob": "^13.0.0",
    "gradient-string": "^2.0.2",
    "js-yaml": "^4.1.1",
    "kleur": "^4.1.5",
    "ora": "^9.1.0",
    "picocolors": "^1.1.1"
  }
}