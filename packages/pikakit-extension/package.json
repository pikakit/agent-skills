{
    "name": "pikakit-skill-engine",
    "displayName": "PikaKit Engine",
    "description": "Real-time auto-learning from IDE diagnostics to generate skills automatically",
    "version": "1.0.0",
    "publisher": "pikakit",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Machine Learning"
    ],
    "keywords": [
        "ai",
        "learning",
        "skills",
        "diagnostics",
        "auto-fix"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "pikakit.startLearning",
                "title": "PikaKit: Start Learning"
            },
            {
                "command": "pikakit.stopLearning",
                "title": "PikaKit: Stop Learning"
            },
            {
                "command": "pikakit.generateSkill",
                "title": "PikaKit: Generate Skill from Patterns"
            },
            {
                "command": "pikakit.viewLessons",
                "title": "PikaKit: View Learned Lessons"
            },
            {
                "command": "pikakit.clearLessons",
                "title": "PikaKit: Clear All Lessons"
            },
            {
                "command": "pikakit.toggleAutoAccept",
                "title": "PikaKit: Toggle Auto-Accept"
            }
        ],
        "keybindings": [
            {
                "command": "pikakit.toggleAutoAccept",
                "key": "ctrl+alt+shift+a",
                "mac": "cmd+alt+shift+a"
            }
        ],
        "configuration": {
            "title": "PikaKit Engine",
            "properties": {
                "pikakit.autoStart": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically start learning on VS Code startup"
                },
                "pikakit.threshold": {
                    "type": "number",
                    "default": 3,
                    "description": "Number of similar errors before generating a skill"
                },
                "pikakit.lessonsPath": {
                    "type": "string",
                    "default": ".agent/lessons.json",
                    "description": "Path to lessons storage file"
                },
                "pikakit.autoAcceptEnabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable auto-accept for Antigravity agent steps (terminal commands, file saves, code edits)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^8.54.0",
        "typescript": "^5.3.0",
        "vitest": "^4.0.18"
    }
}